NODE_ENV=development
PORT=5318
FRONTEND_URL=http://localhost:5317
# Optional comma-separated list for deployed preview/production frontends.
# FRONTEND_URLS=http://localhost:5317,https://paytrack.example.com

DATABASE_URL="mysql://paytrack_user:paytrack_password@localhost:3306/paytrack"

JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
COOKIE_SECRET=change_me_cookie_secret
COOKIE_SAME_SITE=lax

SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM="PayTrack <no-reply@paytrack.local>"
